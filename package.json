{
  "name": "@adametherzlab/schema-to-zod",
  "version": "0.2.0",
  "description": "CLI that takes a sample JSON file or JSON Schema and outputs a TypeScript type plus a matching Zod schema — no hand-rolling",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "tsc --build",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "typescript",
    "bun",
    "nodejs",
    "zod",
    "code-generation",
    "json",
    "cli"
  ],
  "author": {
    "name": "AdametherzLab",
    "url": "https://github.com/AdametherzLab"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdametherzLab/schema-to-zod.git"
  },
  "homepage": "https://github.com/AdametherzLab/schema-to-zod#readme",
  "bugs": {
    "url": "https://github.com/AdametherzLab/schema-to-zod/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/AdametherzLab"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false
}